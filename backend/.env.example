# Aktif AI sağlayıcı: gemini veya deepseek
AI_PROVIDER=gemini

# API anahtarları sunucu .env'inden otomatik kullanılmaz.
# Kullanıcı Gemini veya DeepSeek anahtarını uygulama sidebar'ına girer.
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek API ayarları: https://api-docs.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Frontend origin'leri (virgülle ayrılır). Boş bırakılırsa localhost:3000 ve 127.0.0.1:3000 kullanılır.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Opsiyonel: Vercel preview domainleri gibi pattern'ler için regex.
ALLOWED_ORIGIN_REGEX=

# Admin endpointleri için zorunlu token. Boşsa /api/cache/clear kapalı kalır.
ADMIN_API_TOKEN=

# Sadece Render/Fly/Nginx gibi güvenilir reverse proxy arkasında true yap.
TRUST_PROXY_HEADERS=false

# Kötüye kullanım ve bellek baskısını sınırlayan istek limitleri.
MAX_JSON_BODY_BYTES=11000000
MAX_UPLOAD_BYTES=7000000
MAX_AUDIO_BYTES=5000000
