# Aktif AI sağlayıcı: gemini veya deepseek
AI_PROVIDER=gemini

# Google AI Studio'dan alacağın Gemini API key:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=buraya_gemini_api_anahtarini_yaz
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek API:
# https://api-docs.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Sadece Telegram botu kullanacaksan gerekli:
# https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=
