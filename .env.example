# Aktif AI sağlayıcı: gemini veya deepseek
AI_PROVIDER=gemini

# API anahtarları sunucu .env'inden otomatik kullanılmaz.
# Kullanıcı Gemini veya DeepSeek anahtarını uygulama sidebar'ına girer.
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek API ayarları:
# https://api-docs.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Sadece Telegram botu kullanacaksan gerekli:
# https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=
